    "/api/v1/analyze/upload-url": {
      "post": {
        "tags": [
          "analyze",
          "analyze"
        ],
        "summary": "Request presigned upload URL",
        "description": "Request a presigned URL for direct upload to Cloudflare R2.\n\nThis enables clients to upload videos directly to R2 without going through the API server,\nreducing server load and improving upload performance. The server will later pull the\nvideo from R2 into local MinIO on confirm.\n\n**Steps:**\n1. Call this endpoint to get upload URL and job_id\n2. PUT the video file to the upload_url\n3. Call /analyze/confirm with the job_id to start processing\n\n**Args:**\n- filename: Name of the video file (e.g., \"dance_video.mp4\")\n- content_type: MIME type of the video (default: \"video/mp4\")\n\n**Returns:**\n- upload_url: Presigned URL to upload the video (valid for 15 minutes)\n- job_id: Unique identifier for tracking this analysis\n- s3_key: S3 object key where the file will be stored",
        "operationId": "request_upload_url_api_v1_analyze_upload_url_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Name of the video file",
              "title": "Filename"
            },
            "description": "Name of the video file"
          },
          {
            "name": "content_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "MIME type of the video",
              "default": "video/mp4",
              "title": "Content Type"
            },
            "description": "MIME type of the video"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Request Upload Url Api V1 Analyze Upload Url Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analyze/confirm": {
      "post": {
        "tags": [
          "analyze",
          "analyze"
        ],
        "summary": "Confirm upload and start analysis",
        "description": "Confirm that a video has been uploaded to Cloudflare R2 and start the analysis pipeline.\n\nCall this endpoint after successfully uploading the video using the presigned URL\nfrom /analyze/upload-url. This will pull the video from R2 into local MinIO\nbefore queuing the job.\n\n**Args:**\n- job_id: The job ID received from /analyze/upload-url\n- s3_key: The S3 key received from /analyze/upload-url\n\n**Returns:**\n- Job details and queuing status",
        "operationId": "confirm_upload_and_start_analysis_api_v1_analyze_confirm_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Job ID from upload-url endpoint",
              "title": "Job Id"
            },
            "description": "Job ID from upload-url endpoint"
          },
          {
            "name": "s3_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "S3 key from upload-url endpoint",
              "title": "S3 Key"
            },
            "description": "S3 key from upload-url endpoint"
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Confirm Upload And Start Analysis Api V1 Analyze Confirm Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analyze": {
      "post": {
        "tags": [
          "analyze",
          "analyze"
        ],
        "summary": "Submit video for analysis (legacy)",
        "description": "Upload a dance video for pose estimation analysis.\n\n**DEPRECATED**: This endpoint uploads videos through the API server.\nFor better performance, use the direct upload flow:\n1. POST /analyze/upload-url to get presigned URL\n2. PUT video to the presigned URL\n3. POST /analyze/confirm to start processing\n\nThe video is uploaded to S3 and queued for processing.\nReturns a job_id to track analysis progress.\n\n**Supported formats**: MP4, AVI, MOV",
        "operationId": "submit_video_analysis_api_v1_analyze_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_submit_video_analysis_api_v1_analyze_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Submit Video Analysis Api V1 Analyze Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
