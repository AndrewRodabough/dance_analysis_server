# Environment configuration for Docker Compose
# Copy this to .env.local for local overrides

# PostgreSQL Configuration
DATABASE_URL=postgresql://danceuser:dancepass@postgres:5432/dancedb

# JWT Authentication
# IMPORTANT: Generate a secure key for production: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MinIO/S3 Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dance-videos

# Public endpoint for presigned URLs (must be accessible from client devices)
# For local dev with phone: http://<your-LAN-IP>:9000
# For production with tunnel: https://storage.valoren.click
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Logging
PYTHONUNBUFFERED=1

# Development Settings
USE_MOCK_ANALYSIS=false

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
