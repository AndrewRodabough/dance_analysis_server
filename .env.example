###############################################
# Dance Coach - Example Environment File
#
# Copy this file to `.env` and then edit values
# for your local development or deployment.
#
# IMPORTANT:
# - Never commit your real `.env` to version control.
# - Treat anything marked "CHANGE_ME" or commented out
#   as something you must review before using in prod.
###############################################

###############################################
# General application settings
###############################################

# Whether to use a mock analysis pipeline instead of real GPU/ML work.
# Useful for frontend/backend development without heavy dependencies.
# true  = use mock analysis
# false = use real analysis pipeline
USE_MOCK_ANALYSIS=false

# Log level for backend and workers.
# Common values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Ensure Python output is unbuffered for better Docker logs.
PYTHONUNBUFFERED=1


###############################################
# Authentication / JWT
###############################################

# SECRET: change this in any non-local environment.
# Use a long, random string (at least 32+ chars).
JWT_SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY

# JWT signing algorithm (usually HS256).
JWT_ALGORITHM=HS256

# Access token lifetime (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30


###############################################
# Redis
###############################################

# Internal Redis URL used by backend, workers, and rq-dashboard.
# In Docker, "redis" is the service name, not localhost.
REDIS_URL=redis://redis:6379/0


###############################################
# Database (PostgreSQL)
###############################################

# Credentials used by the Postgres container on first startup.
# Safe defaults for local dev, but use strong passwords in prod.
POSTGRES_USER=danceuser
POSTGRES_PASSWORD=dancepass
POSTGRES_DB=dancedb

# Internal DB URL used by backend and workers.
# In Docker, "postgres" is the service name, not localhost.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}


###############################################
# Object Storage - MinIO (S3-compatible)
###############################################
# This is for local / self-hosted storage inside Docker.

# Internal endpoint for services inside Docker.
S3_ENDPOINT=http://minio:9000

# Public endpoint your frontend or external clients will use.
# For pure local dev, you can leave this as-is or point to localhost.
# Example local: http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000

# MinIO root credentials.
# In production, use dedicated IAM-style users instead of root
# and store these secrets securely.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Bucket name used for storing videos.
S3_BUCKET=dance-videos


###############################################
# Optional: Cloudflare R2 / External S3
###############################################
# Leave empty if you don't use R2 or another S3-compatible service.
# If you do, fill these in and update your application config
# to use them appropriately.

# Example:
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=my-r2-bucket
# R2_ACCESS_KEY=CHANGE_ME_R2_ACCESS_KEY
# R2_SECRET_KEY=CHANGE_ME_R2_SECRET_KEY

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=


###############################################
# Worker / Device configuration
###############################################
# These are generic defaults; actual device type is set
# per worker profile via docker-compose anchors.

# CUDA / NVIDIA GPU workers
# For single-GPU dev machines, "0" is usually fine.
CUDA_VISIBLE_DEVICES=0

# AMD / ROCm workers
HIP_VISIBLE_DEVICES=0

# Device type is wired in docker-compose via:
# - cpu   (video-worker-cpu)
# - cuda  (video-worker-nvidia)
# - rocm  (video-worker-amd)
# - mps   (video-worker-mac)
#
# You typically do NOT change this here; it is set
# by the compose env anchors for each worker profile.
DEVICE_TYPE=cpu


###############################################
# RQ Dashboard
###############################################

# Redis connection used by rq-dashboard container.
RQ_DASHBOARD_REDIS_URL=${REDIS_URL}


###############################################
# Grafana / Observability
###############################################
# These defaults are convenient for dev. For production:
# - Change admin credentials
# - Consider disabling anonymous access or limiting permissions.

# Public root URL where Grafana is served.
# For local dev: http://localhost:3000
GF_SERVER_ROOT_URL=http://localhost:3000

# Admin credentials (change in any real deployment).
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Allow signup via UI? Typically false for internal dashboards.
GF_USERS_ALLOW_SIGN_UP=false

# Allow anonymous access? Consider disabling in prod.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
